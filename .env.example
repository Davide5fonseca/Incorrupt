# ============================================================
#  Incorrupt / DEMS — Template de variáveis de ambiente
#  Copia para .env e preenche.   cp .env.example .env
# ============================================================

# ── IPFS / Pinata (opcional) ───────────────────────────────
# JWT scoped key de https://app.pinata.cloud/developers/api-keys
# Deixa vazio para desligar o backup IPFS.
IPFS_PINATA_KEY=

# ── Google Drive (opcional) ────────────────────────────────
# ID da pasta de destino. Requer google-key.json na raiz.
GOOGLE_DRIVER_FOLDER_ID=

# ── Segredos de segurança (OBRIGATÓRIO em produção) ────────
# Sem LOCAL_DEV=true, o orquestrador ABORTA no arranque se estes
# faltarem ou forem o default de dev.
# JWT: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# AES-256: 64 chars hex (32 bytes)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Validade do JWT
JWT_EXPIRES_IN=8h

# ── PostgreSQL (produção / Docker) ─────────────────────────
# Usados pelo docker-compose (postgres_db e orchestrator). O
# compose ABORTA se POSTGRES_PASSWORD não estiver definida aqui.
POSTGRES_USER=admin
POSTGRES_PASSWORD=
POSTGRES_DB=dems_orchestrator
