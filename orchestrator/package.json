{
  "name": "dems-orchestrator",
  "version": "1.0.0",
  "description": "API Gateway para Sistema de Cadeia de Custódia Distribuída",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:local": "cross-env LOCAL_DEV=true PORT=8888 ts-node-dev --respawn --transpile-only --ignore-watch .db src/server.ts",
    "test": "cross-env TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register --test src/crypto/blockHash.test.ts src/crypto/nodeIdentity.test.ts src/storage/localStorage.test.ts",
    "test:integration": "cross-env LOCAL_DEV=true TS_NODE_TRANSPILE_ONLY=1 node -r ts-node/register --test --test-timeout=120000 src/services/consensus.integration.test.ts"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "exifr": "^7.1.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "form-data": "^4.0.5",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.2.4",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.18",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.8.2",
    "@types/pg": "^8.10.2",
    "cross-env": "^7.0.3",
    "mongodb-memory-server": "^10.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
